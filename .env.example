# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Service Ports ─────────────────────────────────────────────────────────────
PORT=3001
# See libs/constants/src/index.ts → SERVICE_PORTS for all ports
API_GATEWAY_PORT=3001
EVENT_COLLECTOR_PORT=3002
INTENT_ENGINE_PORT=3003
STREAM_PROCESSOR_PORT=3004
WORKER_JOBS_PORT=3005
AUTH_SERVICE_PORT=3010
USER_SERVICE_PORT=3011
SEGMENTATION_SERVICE_PORT=3012
ANALYTICS_SERVICE_PORT=3013
RECOMMENDATION_SERVICE_PORT=3014

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://intent:intent@localhost:5432/intent_platform
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=intent_platform
DATABASE_USER=intent
DATABASE_PASSWORD=intent

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=intent-platform
KAFKA_GROUP_ID=intent-consumer-group
EVENT_COLLECTOR_KAFKA_CLIENT_ID=event-collector
STREAM_PROCESSOR_KAFKA_CLIENT_ID=stream-processor
STREAM_PROCESSOR_KAFKA_GROUP_ID=stream-processor-group

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d
API_KEY_SALT=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── ClickHouse (Analytics Warehouse) ─────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=intent_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_ML_SCORING=false
ENABLE_RECOMMENDATIONS=false

# ── SDK ───────────────────────────────────────────────────────────────────────
SDK_WRITE_KEY=generate-a-random-write-key
INTENT_WRITE_KEY=generate-a-random-write-key

# ── Frontend / API URLs ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
API_GATEWAY_URL=http://localhost:3001

# ── Downstream Service URLs (API Gateway delegates to these) ─────────────────
EVENT_COLLECTOR_URL=http://localhost:3002
INTENT_ENGINE_URL=http://localhost:3003
STREAM_PROCESSOR_URL=http://localhost:3004
WORKER_JOBS_URL=http://localhost:3005
AUTH_SERVICE_URL=http://localhost:3010
USER_SERVICE_URL=http://localhost:3011
SEGMENTATION_SERVICE_URL=http://localhost:3012
ANALYTICS_SERVICE_URL=http://localhost:3013
RECOMMENDATION_SERVICE_URL=http://localhost:3014

# ── Jobs ──────────────────────────────────────────────────────────────────────
EVENT_RETENTION_DAYS=90
